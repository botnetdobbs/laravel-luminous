{
    "name": "botnetdobbs/laravel-luminous",
    "description": "PHP 8 Attribute-driven OpenAPI 3.2 documentation for Laravel",
    "keywords": [
        "laravel",
        "openapi",
        "swagger",
        "api-documentation",
        "php8-attributes",
        "openapi-3.2",
        "laravel-package",
        "rest-api"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0"
    },
    "suggest": {
        "symfony/yaml": "Required for YAML export (php artisan luminous:export --format=yaml)"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Botnetdobbs\\Luminous\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Botnetdobbs\\Luminous\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Botnetdobbs\\Luminous\\LuminousServiceProvider"],
            "aliases": {
                "Luminous": "Botnetdobbs\\Luminous\\LuminousFacade"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-html coverage",
        "analyse": "./vendor/bin/phpstan analyse",
        "lint": "./vendor/bin/pint --test"
    }
}
